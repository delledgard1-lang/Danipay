<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>DaniPay Admin</title>
  <style>
    body { font-family: Arial; padding:20px; background:#f5f5f5; }
    .box { background:white; padding:15px; margin-bottom:10px; border-radius:10px; }
    input, button { width:100%; padding:10px; margin-top:5px; }
    button { background:green; color:white; border:none; }
  </style>
</head>
<body>

<h2>DaniPay Admin</h2>

<div class="box">
  <label>Balance</label>
  <input type="number" id="balance">
</div>

<div class="box">
  <label>Card</label>
  <input type="text" id="card" placeholder="**** **** **** 1234">
</div>

<div class="box">
  <label>Transaction</label>
  <input type="text" id="transaction">
  <button onclick="addTransaction()">Add</button>
  <ul id="list"></ul>
</div>

<button onclick="save()">Save Data</button>

<script>
let transactions = [];

function addTransaction(){
  let t = document.getElementById("transaction").value;
  if(t){
    transactions.push(t);
    let li = document.createElement("li");
    li.textContent = t;
    document.getElementById("list").appendChild(li);
    document.getElementById("transaction").value = "";
  }
}

function save(){
  let data = {
    balance: document.getElementById("balance").value,
    card: document.getElementById("card").value,
    transactions: transactions
  };

  localStorage.setItem("walletData", JSON.stringify(data));
  alert("Saved!");
}
</script>

</body>
</html>
